{
  "name": "create-qpq-app",
  "version": "0.1.5",
  "description": "Scaffold a new quidproquo app — npx create-qpq-app my-app",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/esm/index.js",
  "types": "./lib/commonjs/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": ">=24"
  },
  "files": [
    "lib/**/*",
    "template"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "clean": "npx rimraf lib && npx rimraf template && npx rimraf node_modules",
    "build": "npm run clean && npm run build:esm && npm run build:cjs && npm run build:bin-perms",
    "watch": "tsc -p tsconfig.commonjs.json -w",
    "build:cjs": "tsc -p tsconfig.commonjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:bin-perms": "node -e \"require('fs').chmodSync('lib/commonjs/bin/createQpqApp.js', 0o755)\"",
    "snapshot-template": "node ./scripts/snapshotTemplate.mjs",
    "prepack": "npm run snapshot-template",
    "lint": "npx eslint .",
    "lint:fix": "npx eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joe-coady/quidproquo.git"
  },
  "keywords": [
    "quidproquo",
    "qpq",
    "scaffold",
    "generator"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/joe-coady/quidproquo/issues"
  },
  "homepage": "https://github.com/joe-coady/quidproquo#readme",
  "dependencies": {
    "@inquirer/prompts": "^8.5.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.13",
    "quidproquo-tsconfig": "0.1.5",
    "typescript": "^5.8.2"
  },
  "bin": {
    "create-qpq-app": "./lib/commonjs/bin/createQpqApp.js"
  }
}