# Copy to .env and fill in. Only secrets and per-developer identity belong
# here — environment/account/region/platform live in
# apps/<app>/deploy.config.json ("environments"), selected with
# `qpq go --app <app> --env <name>`. Vars set here override that config.

# Temporary AWS session credentials (SSO / assumed role) — refresh when expired.
export AWS_ACCESS_KEY_ID=""
export AWS_SECRET_ACCESS_KEY=""
export AWS_SESSION_TOKEN=""

# Your actor name — development deploys become feature-scoped actor stacks
# (e.g. docpoc-<svc>-development-<actor>-api). Unset for non-actor deploys.
export ACTOR_NAME=""
