# Dependency directories
node_modules/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Don't commit compiled package output (each package's build dir, e.g.
# quidproquo-core/lib/). Anchored so it doesn't also catch source
# directories named lib/ nested under src/ (e.g. quidproquo-cli/src/lib/).
/*/lib/

# Don't commit env powershell scripts
.envrc.ps1

# Don't commit local env / secret files
.env
.env.local
.env.*.local

# Don't commit test files
tests/**/*

@mf-types

# Test coverage reports
.coverage/
coverage/

dist/

cdk.context.json

# Throwaway local benchmark scripts
benchmarks/